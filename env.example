# Path to the Google service account JSON key file (upload as a Render secret file)
GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json

# Google Drive folder where audio/photo files will be stored
# (create a folder, share it with the service account's email, copy its ID from the URL)
GDRIVE_FOLDER_ID=

# Google Sheet used as the lead database
# (share the sheet with the service account's email, copy the ID from the URL)
GSHEET_SPREADSHEET_ID=
GSHEET_TAB_NAME=Leads

# n8n webhook URL that kicks off the AI processing + follow-up workflow
N8N_WEBHOOK_URL=

# Comma-separated list of allowed origins for CORS (your Vercel frontend URL)
ALLOWED_ORIGINS=https://your-frontend.vercel.app
